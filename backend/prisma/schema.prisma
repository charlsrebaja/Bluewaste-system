generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  CITIZEN
  LGU_ADMIN
  FIELD_WORKER
}

enum ReportStatus {
  PENDING
  VERIFIED
  CLEANUP_SCHEDULED
  IN_PROGRESS
  CLEANED
  REJECTED
}

enum WasteCategory {
  SOLID_WASTE
  HAZARDOUS
  LIQUID
  RECYCLABLE
  ORGANIC
  ELECTRONIC
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ImageType {
  REPORT
  CLEANUP
}

enum NotificationType {
  NEW_REPORT
  STATUS_CHANGE
  ASSIGNMENT
  SYSTEM
}

// ==================== MODELS ====================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      Role     @default(CITIZEN)
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barangayId String?
  barangay   Barangay? @relation(fields: [barangayId], references: [id])

  // Reports submitted by the user
  reports         Report[]        @relation("ReporterReports")
  // Reports assigned to the user (field worker)
  assignedReports Report[]        @relation("AssignedReports")
  // Status changes made by the user
  statusChanges   StatusHistory[]
  // Notifications for the user
  notifications   Notification[]
  // Activity logs
  activityLogs    ActivityLog[]

  @@index([role])
  @@index([email])
}

model Report {
  id          String        @id @default(uuid())
  title       String
  description String
  category    WasteCategory
  status      ReportStatus  @default(PENDING)
  priority    Priority      @default(MEDIUM)
  latitude    Float
  longitude   Float
  address     String?
  isAnonymous Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Reporter (nullable for anonymous)
  reporterId String?
  reporter   User?   @relation("ReporterReports", fields: [reporterId], references: [id])

  // Assigned field worker
  assignedToId String?
  assignedTo   User?   @relation("AssignedReports", fields: [assignedToId], references: [id])

  // Barangay
  barangayId String?
  barangay   Barangay? @relation(fields: [barangayId], references: [id])

  // Related records
  images        ReportImage[]
  statusHistory StatusHistory[]
  notifications Notification[]

  @@index([status])
  @@index([category])
  @@index([barangayId])
  @@index([createdAt])
  @@index([reporterId])
  @@index([assignedToId])
  @@index([latitude, longitude])
}

model ReportImage {
  id        String    @id @default(uuid())
  imageUrl  String
  publicId  String    // Cloudinary public ID
  type      ImageType @default(REPORT)
  createdAt DateTime  @default(now())

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Barangay {
  id              String  @id @default(uuid())
  name            String  @unique
  latitude        Float
  longitude       Float
  boundaryGeoJSON Json?
  createdAt       DateTime @default(now())

  users   User[]
  reports Report[]

  @@index([name])
}

model StatusHistory {
  id             String       @id @default(uuid())
  previousStatus ReportStatus?
  newStatus      ReportStatus
  notes          String?
  createdAt      DateTime     @default(now())

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  @@index([reportId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reportId String?
  report   Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
